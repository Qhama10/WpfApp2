<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="774"
        Width="1044"
        Loaded="Window_Loaded"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="75"/>
        </Grid.RowDefinitions>

        <!-- TOP BUTTONS -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="10,0,0,10"
                    Grid.Row="0">

            <Button x:Name="BtnChatbot"
                    Content="Chat History"
                    Width="140"
                    Height="45"
                    Margin="5"
                    Background="LimeGreen"
                    Foreground="Black"
                    FontWeight="Bold"
                    FontSize="15"
                    Click="BtnChatbot_Click"/>

            <Button x:Name="BtnHelp"
                    Content="Help"
                    Width="140"
                    Height="45"
                    Margin="5"
                    Background="DarkGreen"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="15"
                    Click="BtnHelp_Click"/>
        </StackPanel>

        <!-- HEADER -->
        <Border Grid.Row="1"
                Background="#1F1F1F"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">

            <TextBlock FontFamily="Consolas"
                       FontSize="18"
                       Foreground="Cyan"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Text="🛡 CYBERSECURITY AWARENESS BOT 🛡
____         __       ____ _           _   
/ ___|  __ _ / _| ___ / ___| |__   __ _| |_ 
\___ \ / _` | |_ / _ \ |   | '_ \ / _` | __|
 ___) | (_| |  _|  __/ |___| | | | (_| | |_ 
|____/ \__,_|_|  \___|\____|_| |_|\__,_|\__|
Stay safe. Stay smart. Stay secure."/>
        </Border>

        <!-- MAIN CHAT AREA -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- CHAT HISTORY (IMPORTANT) -->
            <ListBox x:Name="ChatHistory"
                     Grid.Column="0"
                     Margin="0,0,10,0"
                     Background="#1E1E1E"
                     Foreground="White"
                     FontSize="18"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"/>

            <!-- SIDE PANEL -->
            <GroupBox Header="Cybersecurity Tips"
                      Grid.Column="1"
                      Background="#1F1F1F"
                      Foreground="Lime"
                      FontWeight="Bold"
                      FontSize="15">

                <StackPanel Margin="10">

                    <TextBlock Text="Suggested Questions"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="• What is cybersecurity?" Foreground="Gainsboro" Margin="0,5"/>
                    <TextBlock Text="• Phishing tips" Foreground="Gainsboro" Margin="0,5"/>
                    <TextBlock Text="• Password safety" Foreground="Gainsboro" Margin="0,5"/>
                    <TextBlock Text="• Privacy protection" Foreground="Gainsboro" Margin="0,5"/>
                    <TextBlock Text="• Online scams" Foreground="Gainsboro" Margin="0,5"/>

                    <Separator Margin="0,15,0,15"/>

                    <TextBlock Text="Features"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="✔ Keyword Recognition" Foreground="Lime" Margin="0,5"/>
                    <TextBlock Text="✔ Random Responses" Foreground="Lime" Margin="0,5"/>
                    <TextBlock Text="✔ Memory Recall" Foreground="Lime" Margin="0,5"/>

                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- INPUT AREA -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

            <TextBox x:Name="UserInput"
                     Width="750"
                     Height="50"
                     FontSize="19"
                     Margin="0,0,10,0"
                     Background="#2B2B2B"
                     Foreground="White"
                     BorderBrush="Lime"
                     Padding="10"/>

            <Button Content="SEND"
                    Width="120"
                    Height="50"
                    Background="LimeGreen"
                    Foreground="Black"
                    FontWeight="Bold"
                    FontSize="16"
                    Click="SendButton_Click"/>

            <Button Content="EXIT"
                    Width="120"
                    Height="50"
                    Margin="10,0,0,0"
                    Background="Red"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="16"
                    Click="ExitButton_Click"/>

        </StackPanel>

    </Grid>
</Window>